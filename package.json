{
  "name": "klip-saas",
  "version": "0.0.1",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "turbo run db:migrate --filter=@klip/backend",
    "db:seed": "turbo run db:seed --filter=@klip/backend",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "agent:dev": "cd apps/langgraph-agent && python -m uvicorn src.main:app --reload --port 8001",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/dist apps/*/.next apps/*/.turbo packages/*/node_modules packages/*/dist"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  }
}
