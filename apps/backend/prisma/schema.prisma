generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects        Project[]
  edits           Edit[]
  motionGraphics  MotionGraphic[]
  exportJobs      ExportJob[]
}

model Project {
  id         String    @id @default(cuid())
  userId     String
  title      String
  youtubeUrl String
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos Video[]
  clips  Clip[]
  edits  Edit[]
}

model Video {
  id             String   @id @default(cuid())
  projectId      String
  youtubeUrl     String
  r2Url          String
  r2Key          String
  durationMs     Int      @default(0)
  thumbnailUrl   String?
  createdAt      DateTime @default(now())

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  transcript Transcript?
}

model Transcript {
  id        String   @id @default(cuid())
  videoId   String   @unique
  fullText  String
  rawJson   Json?
  createdAt DateTime @default(now())

  video    Video                @relation(fields: [videoId], references: [id], onDelete: Cascade)
  segments TranscriptSegment[]
}

model TranscriptSegment {
  id           String @id @default(cuid())
  transcriptId String
  index        Int
  text         String
  startMs      Int
  endMs        Int

  transcript Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
}

model Clip {
  id                String   @id @default(cuid())
  projectId         String
  title             String
  startSegmentIndex Int
  endSegmentIndex   Int
  startMs           Int
  endMs             Int
  durationMs        Int
  reasoning         String
  viralScore        Float    @default(0)
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  edits   Edit[]
}

model Edit {
  id        String    @id @default(cuid())
  clipId    String
  projectId String
  userId    String
  status    String    @default("DRAFT")
  r2Url     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  clip    Clip           @relation(fields: [clipId], references: [id], onDelete: Cascade)
  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  segments  EditSegment[]
  exportJobs ExportJob[]
}

model EditSegment {
  id          String @id @default(cuid())
  editId      String
  segmentIndex Int
  type        String @default("original")
  brollUrl    String?
  brollPrompt String?

  edit Edit @relation(fields: [editId], references: [id], onDelete: Cascade)

  @@unique([editId, segmentIndex])
}

model MotionGraphic {
  id            String    @id @default(cuid())
  userId        String
  prompt        String
  template      String
  inputProps    Json?
  r2Url         String?
  r2Key         String?
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExportJob {
  id        String    @id @default(cuid())
  editId    String
  userId    String
  format    String
  resolution String
  quality   String
  status    String    @default("QUEUED")
  progress  Int       @default(0)
  r2Url     String?
  r2Key     String?
  error     String?
  createdAt DateTime  @default(now())
  completedAt DateTime?

  edit Edit @relation(fields: [editId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
